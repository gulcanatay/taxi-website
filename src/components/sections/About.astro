---
import { Shield, Clock, ThumbsUp, UserCheck } from "@lucide/astro";
import type { Translations } from "../../i18n/types";

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const icons = [Shield, Clock, ThumbsUp, UserCheck];
---

<section id="about" class="py-12 bg-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Text -->
      <div>
        <p class="text-taxi-500 font-semibold text-sm uppercase tracking-wider mb-2">
          {t.about.tagline}
        </p>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-6">
          {t.about.title}
        </h2>
        <p class="text-gray-600 leading-relaxed mb-6">
          {t.about.paragraph1}
        </p>
        <p class="text-gray-600 leading-relaxed">
          {t.about.paragraph2}
        </p>
      </div>

      <!-- Values -->
      <div class="space-y-6">
        {t.about.values.map((value, i) => {
          const Icon = icons[i];
          return (
            <div class="flex gap-4">
              <div class="flex-shrink-0 inline-flex items-center justify-center rounded-xl bg-taxi-50 p-3 text-taxi-500">
                <Icon class="h-6 w-6" />
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-1">{value.title}</h3>
                <p class="text-sm text-gray-600">{value.description}</p>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>
