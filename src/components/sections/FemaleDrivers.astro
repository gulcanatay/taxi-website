---
import { UserCheck, ShieldCheck, Heart } from "@lucide/astro";
import { siteConfig } from "../../config/site";
import type { Translations } from "../../i18n/types";

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const whatsappUrl = `https://wa.me/${siteConfig.whatsapp.number}?text=${encodeURIComponent(t.whatsapp.message)}`;
const icons = [UserCheck, ShieldCheck, Heart];
---

<section id="drivers" class="py-12 bg-gray-50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <p class="text-taxi-500 font-semibold text-sm uppercase tracking-wider mb-2">
        {t.femaleDrivers.tagline}
      </p>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">
        {t.femaleDrivers.title}
      </h2>
      <p class="mt-4 text-gray-600 max-w-2xl mx-auto">
        {t.femaleDrivers.description}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
      {t.femaleDrivers.benefits.map((benefit, i) => {
        const Icon = icons[i];
        return (
          <div class="rounded-2xl bg-white border border-gray-100 p-6 text-center">
            <div class="inline-flex items-center justify-center rounded-xl bg-taxi-50 p-3 text-taxi-500 mb-4">
              <Icon class="h-6 w-6" />
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">{benefit.title}</h3>
            <p class="text-sm text-gray-600">{benefit.description}</p>
          </div>
        );
      })}
    </div>

    <div class="text-center">
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 rounded-full bg-taxi-400 px-8 py-4 text-lg font-bold text-gray-900 hover:bg-taxi-500 transition-colors"
      >
        {t.femaleDrivers.cta}
      </a>
    </div>
  </div>
</section>
