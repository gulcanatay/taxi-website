---
import ReservationForm from "../ui/ReservationForm.astro";
import { Banknote } from "@lucide/astro";
import type { Translations } from "../../i18n/types";

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="reservation" class="py-20 bg-gray-50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="text-taxi-500 font-semibold text-sm uppercase tracking-wider mb-2">
        {t.contact.tagline}
      </p>
      <h2 class="text-3xl sm:text-4xl font-bold text-dark">
        {t.contact.title}
      </h2>
      <p class="mt-4 text-gray-600 max-w-2xl mx-auto">
        {t.contact.description}
      </p>
    </div>

    <div class="max-w-3xl mx-auto">
      <ReservationForm t={t} />

      <div class="mt-8 text-center">
        <p class="text-sm text-gray-500 mb-3">{t.payment.title}</p>
        <div class="flex flex-wrap justify-center items-center gap-3">
          <span class="inline-flex items-center gap-1.5 rounded-full bg-white border border-gray-200 px-4 py-2 text-sm text-gray-700">
            <Banknote class="h-4 w-4 text-taxi-500" />
            {t.payment.cash}
          </span>
          <div class="flex items-center justify-center h-10 px-3 rounded-full bg-white border border-gray-200">
            <img src="/Visa.png" alt="Visa" class="h-4 w-auto" />
          </div>
          <div class="flex items-center justify-center h-10 px-3 rounded-full bg-white border border-gray-200">
            <img src="/Mastercard.png" alt="Mastercard" class="h-5 w-auto" />
          </div>
          <div class="flex items-center justify-center h-10 px-3 rounded-full bg-white border border-gray-200">
            <img src="/Maestro.svg" alt="Maestro" class="h-4 w-auto" />
          </div>
          <div class="flex items-center justify-center h-10 px-3 rounded-full bg-white border border-gray-200">
            <img src="/EC.svg" alt="EC" class="h-5 w-auto" />
          </div>
          <div class="flex items-center justify-center h-10 px-3 rounded-full bg-white border border-gray-200">
            <img src="/ApplePay.png" alt="Apple Pay" class="h-4 w-auto" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
