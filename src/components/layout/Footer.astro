---
import { Phone } from "@lucide/astro";
import { siteConfig } from "../../config/site";
---

<footer class="bg-dark text-gray-300">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-col items-center text-center gap-6">
      <a href="/">
        <img src="/Logo_Yellow.png" alt={siteConfig.name} class="h-14" />
      </a>

      <a
        href={`tel:${siteConfig.phone}`}
        class="inline-flex items-center gap-2 rounded-full bg-taxi-400 px-6 py-3 text-base font-bold text-dark hover:bg-taxi-500 transition-colors"
      >
        <Phone class="h-5 w-5" />
        {siteConfig.phoneDisplay}
      </a>
    </div>

    <div class="mt-10 pt-8 border-t border-gray-800 flex flex-col sm:flex-row justify-between items-center gap-4 text-sm text-gray-500">
      <p>&copy; {new Date().getFullYear()} {siteConfig.name}. Alle Rechte vorbehalten.</p>
      <div class="flex gap-6">
        <a href="/impressum" class="hover:text-white transition-colors">Impressum</a>
        <a href="/datenschutz" class="hover:text-white transition-colors">Datenschutz</a>
      </div>
    </div>
  </div>
</footer>
