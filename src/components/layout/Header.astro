---
import { Phone, Menu, X } from "@lucide/astro";
import { siteConfig } from "../../config/site";
import LanguageSwitcher from "../ui/LanguageSwitcher.astro";
import type { Locale } from "../../i18n";
import type { Translations } from "../../i18n/types";

interface Props {
  locale: Locale;
  t: Translations;
  alternateUrls: Record<Locale, string>;
  solid?: boolean;
}

const { locale, t, alternateUrls, solid = false } = Astro.props;
const whatsappUrl = `https://wa.me/${siteConfig.whatsapp.number}?text=${encodeURIComponent(t.whatsapp.message)}`;
---

<header id="site-header" class:list={["fixed top-0 left-0 right-0 z-50 transition-[background-color] duration-200 pt-[env(safe-area-inset-top)]", solid && "bg-dark"]} data-solid={solid ? "true" : undefined}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="relative flex h-20 items-center justify-between">
      <!-- Logo -->
      <a href={locale === "de" ? "/" : `/${locale}/`} class="-ml-6 md:ml-0">
        <img src="/Logo_Yellow.png" alt={siteConfig.name} class="h-12" />
      </a>

      <!-- Desktop Nav (centered links) -->
      <nav class="hidden md:flex items-center justify-center gap-8 absolute left-1/2 -translate-x-1/2">
        {t.nav.map((item) => (
          <a
            href={locale === "de" ? item.href : `/${locale}${item.href}`}
            class="text-sm font-bold text-white hover:text-taxi-400 transition-colors"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Right side: Language + Phone -->
      <div class="hidden md:flex items-center gap-4">
        <LanguageSwitcher currentLocale={locale} alternateUrls={alternateUrls} />
        <a
          href={`tel:${siteConfig.phone}`}
          data-track="phone"
          class="inline-flex items-center gap-2 rounded-full bg-taxi-400 px-4 py-2 text-sm font-semibold text-dark hover:bg-taxi-500 transition-colors"
        >
          <Phone class="h-4 w-4" />
          {siteConfig.phoneDisplay}
        </a>
      </div>

      <!-- Mobile: Language + Menu Button -->
      <div class="flex md:hidden items-center gap-1">
        <LanguageSwitcher currentLocale={locale} alternateUrls={alternateUrls} compact />
        <button
          id="mobile-menu-btn"
          class="p-2 text-taxi-400 hover:text-white"
          aria-label={t.header.menuOpen}
        >
          <Menu class="h-6 w-6" id="menu-icon-open" />
          <X class="h-6 w-6 hidden" id="menu-icon-close" />
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Nav (full-screen overlay) -->
  <div id="mobile-menu" class="hidden md:hidden fixed inset-0 top-0 z-[-1] bg-dark pt-[calc(5rem+env(safe-area-inset-top))] overflow-y-auto opacity-0 transition-opacity duration-300" data-menu-overlay>
    <nav class="flex flex-col items-center px-4 py-6 gap-5 text-center border-t border-white/10">
      {t.nav.map((item) => (
        <a
          href={locale === "de" ? item.href : `/${locale}${item.href}`}
          class="menu-item mobile-nav-link text-base font-bold text-white hover:text-taxi-400 transition-colors"
        >
          {item.label}
        </a>
      ))}
      <div class="menu-item w-full border-b border-white/10"></div>
      <div class="menu-item flex flex-col items-center">
        <p class="text-xs text-gray-400 uppercase tracking-wider mb-2">{t.header.whatsappBooking}</p>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-track="whatsapp"
          class="inline-flex items-center gap-2 rounded-full bg-green-500 px-4 py-2 text-sm font-semibold text-white hover:bg-green-600 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
          </svg>
          WhatsApp
        </a>
      </div>
      <div class="menu-item flex flex-col items-center">
        <p class="text-xs text-gray-400 uppercase tracking-wider mb-2">{t.header.directCall}</p>
        <a
          href={`tel:${siteConfig.phone}`}
          data-track="phone"
          class="inline-flex items-center gap-2 rounded-full bg-taxi-400 px-4 py-2 text-sm font-semibold text-dark hover:bg-taxi-500 transition-colors"
        >
          <Phone class="h-4 w-4" />
          {siteConfig.phoneDisplay}
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("menu-icon-open");
  const iconClose = document.getElementById("menu-icon-close");
  const header = document.getElementById("site-header");
  const menuItems = menu?.querySelectorAll(".menu-item") ?? [];

  function isMenuOpen() {
    return menu?.dataset.open === "true";
  }

  const isSolid = header?.dataset.solid === "true";

  function updateHeaderBg() {
    if (isSolid || isMenuOpen() || window.scrollY > 50) {
      header?.classList.add("bg-dark");
    } else {
      header?.classList.remove("bg-dark");
    }
  }

  function resetItems() {
    menuItems.forEach((item) => {
      (item as HTMLElement).style.opacity = "0";
      (item as HTMLElement).style.transform = "translateY(16px)";
    });
  }

  function animateItemsIn() {
    menuItems.forEach((item, i) => {
      const el = item as HTMLElement;
      el.style.transition = "none";
      el.style.opacity = "0";
      el.style.transform = "translateY(16px)";
      requestAnimationFrame(() => {
        el.style.transition = `opacity 0.35s ease ${i * 0.06}s, transform 0.35s ease ${i * 0.06}s`;
        el.style.opacity = "1";
        el.style.transform = "translateY(0)";
      });
    });
  }

  function openMenu() {
    if (!menu) return;
    resetItems();
    menu.classList.remove("hidden");
    menu.dataset.open = "true";
    // Trigger overlay fade-in on next frame
    requestAnimationFrame(() => {
      menu.classList.remove("opacity-0");
      menu.classList.add("opacity-100");
      animateItemsIn();
    });
    iconOpen?.classList.add("hidden");
    iconClose?.classList.remove("hidden");
    document.body.classList.add("overflow-hidden");
    updateHeaderBg();
  }

  function closeMenu() {
    if (!menu) return;
    menu.classList.remove("opacity-100");
    menu.classList.add("opacity-0");
    menu.dataset.open = "false";
    iconOpen?.classList.remove("hidden");
    iconClose?.classList.add("hidden");
    document.body.classList.remove("overflow-hidden");
    // Wait for fade-out then hide
    setTimeout(() => {
      if (!isMenuOpen()) {
        menu.classList.add("hidden");
      }
    }, 300);
    updateHeaderBg();
  }

  btn?.addEventListener("click", () => {
    isMenuOpen() ? closeMenu() : openMenu();
  });

  window.addEventListener("scroll", updateHeaderBg);

  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });
</script>
