---
import type { Translations } from "../../i18n/types";
import type { Locale } from "../../i18n";
import { localePath } from "../../i18n";

interface Props {
  t: Translations;
  locale: Locale;
}

const { t, locale } = Astro.props;
const privacyUrl = localePath(locale, t.routes.datenschutz);
---

<div
  id="cookie-consent-banner"
  class="fixed bottom-0 left-0 right-0 z-[9999] hidden"
  role="dialog"
  aria-label={t.cookieConsent.bannerText}
>
  <div class="bg-dark/95 backdrop-blur-sm border-t border-white/10">
    <div class="mx-auto max-w-5xl px-4 py-4 sm:px-6 sm:py-5">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between sm:gap-4">
        <p class="text-sm text-gray-300 sm:flex-1">
          {t.cookieConsent.bannerText}
          {" "}
          <a
            href={privacyUrl}
            class="text-taxi-400 underline hover:text-taxi-300 transition-colors"
          >
            {t.cookieConsent.privacyLink}
          </a>
        </p>
        <div class="flex gap-3 shrink-0">
          <button
            id="cookie-reject"
            class="rounded-lg border border-white/20 px-4 py-2 text-sm font-medium text-white hover:bg-white/10 transition-colors cursor-pointer"
          >
            {t.cookieConsent.rejectButton}
          </button>
          <button
            id="cookie-accept"
            class="rounded-lg bg-taxi-400 px-4 py-2 text-sm font-semibold text-dark hover:bg-taxi-500 transition-colors cursor-pointer"
          >
            {t.cookieConsent.acceptButton}
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var banner = document.getElementById("cookie-consent-banner");
    var stored = localStorage.getItem("consent_marketing");

    function grantConsent() {
      window.dataLayer = window.dataLayer || [];
      function gtag() { window.dataLayer.push(arguments); }
      gtag("consent", "update", {
        ad_storage: "granted",
        ad_user_data: "granted",
        ad_personalization: "granted",
        analytics_storage: "granted",
      });
    }

    // Apply stored consent
    if (stored === "granted") {
      grantConsent();
    }

    // Show banner if no choice made
    if (!stored && banner) {
      banner.classList.remove("hidden");
    }

    // Accept button
    var acceptBtn = document.getElementById("cookie-accept");
    if (acceptBtn) {
      acceptBtn.addEventListener("click", function () {
        localStorage.setItem("consent_marketing", "granted");
        grantConsent();
        if (banner) banner.classList.add("hidden");
      });
    }

    // Reject button
    var rejectBtn = document.getElementById("cookie-reject");
    if (rejectBtn) {
      rejectBtn.addEventListener("click", function () {
        localStorage.setItem("consent_marketing", "denied");
        if (banner) banner.classList.add("hidden");
      });
    }

    // Reset button on privacy policy page
    var resetBtn = document.getElementById("reset-cookie-consent");
    if (resetBtn) {
      resetBtn.addEventListener("click", function () {
        localStorage.removeItem("consent_marketing");
        window.location.reload();
      });
    }
  })();
</script>
