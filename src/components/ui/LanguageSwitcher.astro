---
import { ChevronDown } from "@lucide/astro";
import type { Locale } from "../../i18n";

interface Props {
  currentLocale: Locale;
  alternateUrls: Record<Locale, string>;
  compact?: boolean;
  class?: string;
}

const { currentLocale, alternateUrls, compact = false, class: className = "" } = Astro.props;

const languages: Array<{ code: Locale; label: string; short: string; flag: string }> = [
  { code: "de", label: "Deutsch", short: "DE", flag: "🇩🇪" },
  { code: "en", label: "English", short: "EN", flag: "🇬🇧" },
  { code: "fr", label: "Français", short: "FR", flag: "🇫🇷" },
];

const current = languages.find((l) => l.code === currentLocale)!;
const others = languages.filter((l) => l.code !== currentLocale);
---

<div class:list={["relative", className]} data-lang-switcher>
  <button
    type="button"
    class:list={[
      "flex items-center gap-2 text-sm font-semibold text-white hover:text-taxi-400 transition-colors rounded-lg cursor-pointer",
      compact ? "px-2 py-1.5 gap-1.5" : "px-3 py-2",
    ]}
    data-lang-toggle
    aria-expanded="false"
    aria-haspopup="true"
  >
    <span class="text-base leading-none">{current.flag}</span>
    <span>{compact ? current.short : current.label}</span>
    <ChevronDown class:list={["transition-transform", compact ? "h-3.5 w-3.5" : "h-4 w-4"]} data-lang-chevron />
  </button>

  <div
    class:list={[
      "absolute top-full mt-1 rounded-xl bg-dark/95 backdrop-blur-sm border border-white/10 shadow-xl overflow-hidden opacity-0 invisible translate-y-1 transition-all duration-200",
      compact ? "right-0 min-w-[120px]" : "right-0 min-w-[160px]",
    ]}
    data-lang-dropdown
  >
    {others.map((lang) => (
      <a
        href={alternateUrls[lang.code]}
        hreflang={lang.code}
        data-lang-code={lang.code}
        class:list={[
          "flex items-center text-sm text-gray-300 hover:text-white hover:bg-white/10 transition-colors",
          compact ? "gap-2 px-3 py-2.5" : "gap-3 px-4 py-3",
        ]}
      >
        <span class="text-base leading-none">{lang.flag}</span>
        <span>{compact ? lang.short : lang.label}</span>
      </a>
    ))}
  </div>
</div>

<script>
  document.querySelectorAll("[data-lang-switcher]").forEach((switcher) => {
    const toggle = switcher.querySelector("[data-lang-toggle]");
    const dropdown = switcher.querySelector("[data-lang-dropdown]") as HTMLElement;
    const chevron = switcher.querySelector("[data-lang-chevron]") as HTMLElement;

    if (!toggle || !dropdown || !chevron) return;

    function open() {
      dropdown.classList.remove("opacity-0", "invisible", "translate-y-1");
      dropdown.classList.add("opacity-100", "visible", "translate-y-0");
      chevron.classList.add("rotate-180");
      toggle!.setAttribute("aria-expanded", "true");
    }

    function close() {
      dropdown.classList.add("opacity-0", "invisible", "translate-y-1");
      dropdown.classList.remove("opacity-100", "visible", "translate-y-0");
      chevron.classList.remove("rotate-180");
      toggle!.setAttribute("aria-expanded", "false");
    }

    // Save manual language preference when user clicks a language link
    switcher.querySelectorAll("a[data-lang-code]").forEach((link) => {
      link.addEventListener("click", () => {
        const code = (link as HTMLElement).dataset.langCode;
        if (code) localStorage.setItem("lang-preference", code);
      });
    });

    toggle.addEventListener("click", (e) => {
      e.stopPropagation();
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      if (isOpen) {
        close();
      } else {
        open();
      }
    });

    document.addEventListener("click", (e) => {
      if (!switcher.contains(e.target as Node)) {
        close();
      }
    });
  });
</script>
