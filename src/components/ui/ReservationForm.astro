---
import { siteConfig } from "../../config/site";

interface Props {
  defaultTo?: string;
  id?: string;
}

const { defaultTo = "", id = "reservation-form" } = Astro.props;
const whatsappNumber = siteConfig.whatsapp.number;
---

<form id={id} class="rounded-2xl bg-white border border-gray-100 p-8 space-y-6">
  <div>
    <label for={`${id}-from`} class="block text-sm font-medium text-gray-700 mb-1">Von (Abholort)</label>
    <input
      type="text"
      id={`${id}-from`}
      name="from"
      required
      class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-taxi-400 focus:border-transparent"
      placeholder="z.B. Hauptbahnhof München"
    />
  </div>
  <div>
    <label for={`${id}-to`} class="block text-sm font-medium text-gray-700 mb-1">Nach (Zielort)</label>
    <input
      type="text"
      id={`${id}-to`}
      name="to"
      required
      value={defaultTo}
      class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-taxi-400 focus:border-transparent"
      placeholder="z.B. Flughafen München"
    />
  </div>
  <div>
    <label for={`${id}-datetime`} class="block text-sm font-medium text-gray-700 mb-1">Datum & Uhrzeit</label>
    <input
      type="datetime-local"
      id={`${id}-datetime`}
      name="datetime"
      required
      class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-taxi-400 focus:border-transparent"
    />
  </div>
  <div>
    <label for={`${id}-phone`} class="block text-sm font-medium text-gray-700 mb-1">Telefon</label>
    <input
      type="tel"
      id={`${id}-phone`}
      name="phone"
      required
      class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-taxi-400 focus:border-transparent"
      placeholder="z.B. 0170 1234567"
    />
  </div>
  <div>
    <label for={`${id}-email`} class="block text-sm font-medium text-gray-700 mb-1">E-Mail</label>
    <input
      type="email"
      id={`${id}-email`}
      name="email"
      required
      class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-taxi-400 focus:border-transparent"
      placeholder="ihre@email.de"
    />
  </div>
  <button
    type="submit"
    class="w-full rounded-full bg-taxi-400 px-6 py-3 font-semibold text-dark hover:bg-taxi-500 transition-colors"
  >
    Fahrt reservieren
  </button>
</form>

<script define:vars={{ whatsappNumber, id }}>
  const form = document.getElementById(id);
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const text = [
      "Neue Reservierung:",
      `Von: ${data.get("from")}`,
      `Nach: ${data.get("to")}`,
      `Datum: ${data.get("datetime")}`,
      `Telefon: ${data.get("phone")}`,
      `E-Mail: ${data.get("email")}`,
    ].join("\n");
    window.open(
      `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(text)}`,
      "_blank"
    );
  });
</script>
