---
import { siteConfig } from "../../config/site";
import type { Translations } from "../../i18n/types";

interface Props {
  t: Translations;
  defaultTo?: string;
  id?: string;
}

const { t, defaultTo = "", id = "reservation-form" } = Astro.props;
const whatsappNumber = siteConfig.whatsapp.number;
const whatsappPrefix = t.form.whatsappPrefix;
const fromField = t.form.fromField;
const toField = t.form.toField;
const dateField = t.form.dateField;
const phoneField = t.form.phoneField;
const emailField = t.form.emailField;
---

<form id={id} class="rounded-2xl bg-white border border-gray-100 p-8 space-y-6">
  <div>
    <label for={`${id}-from`} class="block text-sm font-medium text-gray-700 mb-1">{t.form.fromLabel}</label>
    <input
      type="text"
      id={`${id}-from`}
      name="from"
      required
      class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-taxi-400 focus:border-transparent"
      placeholder={t.form.fromPlaceholder}
    />
  </div>
  <div>
    <label for={`${id}-to`} class="block text-sm font-medium text-gray-700 mb-1">{t.form.toLabel}</label>
    <input
      type="text"
      id={`${id}-to`}
      name="to"
      required
      value={defaultTo}
      class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-taxi-400 focus:border-transparent"
      placeholder={t.form.toPlaceholder}
    />
  </div>
  <div>
    <label for={`${id}-datetime`} class="block text-sm font-medium text-gray-700 mb-1">{t.form.datetimeLabel}</label>
    <input
      type="datetime-local"
      id={`${id}-datetime`}
      name="datetime"
      required
      class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-taxi-400 focus:border-transparent"
    />
  </div>
  <div>
    <label for={`${id}-phone`} class="block text-sm font-medium text-gray-700 mb-1">{t.form.phoneLabel}</label>
    <input
      type="tel"
      id={`${id}-phone`}
      name="phone"
      required
      class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-taxi-400 focus:border-transparent"
      placeholder={t.form.phonePlaceholder}
    />
  </div>
  <div>
    <label for={`${id}-email`} class="block text-sm font-medium text-gray-700 mb-1">{t.form.emailLabel}</label>
    <input
      type="email"
      id={`${id}-email`}
      name="email"
      required
      class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-taxi-400 focus:border-transparent"
      placeholder={t.form.emailPlaceholder}
    />
  </div>
  <button
    type="submit"
    class="w-full rounded-full bg-taxi-400 px-6 py-3 font-semibold text-dark hover:bg-taxi-500 transition-colors"
  >
    {t.form.submit}
  </button>
</form>

<script define:vars={{ whatsappNumber, id, whatsappPrefix, fromField, toField, dateField, phoneField, emailField }}>
  const form = document.getElementById(id);
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const text = [
      whatsappPrefix,
      `${fromField}: ${data.get("from")}`,
      `${toField}: ${data.get("to")}`,
      `${dateField}: ${data.get("datetime")}`,
      `${phoneField}: ${data.get("phone")}`,
      `${emailField}: ${data.get("email")}`,
    ].join("\n");
    window.open(
      `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(text)}`,
      "_blank"
    );
  });
</script>
