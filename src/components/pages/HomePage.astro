---
import Layout from "../../layouts/Layout.astro";
import Header from "../layout/Header.astro";
import Footer from "../layout/Footer.astro";
import Hero from "../sections/Hero.astro";
import Services from "../sections/Services.astro";
import Contact from "../sections/Contact.astro";
import Reviews from "../sections/Reviews.astro";
import { getTranslations, getAlternateUrls } from "../../i18n";
import type { Locale } from "../../i18n";
import { siteConfig } from "../../config/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
const alternateUrls = getAlternateUrls("home");
---

<Layout
  title={t.meta.title}
  description={t.meta.description}
  locale={locale}
  t={t}
  alternateUrls={alternateUrls}
>
  <Header locale={locale} t={t} alternateUrls={alternateUrls} />
  <main>
    <Hero t={t} />
    <Services t={t} />
    <Reviews t={t} />
    <Contact t={t} />
  </main>
  <Footer locale={locale} t={t} alternateUrls={alternateUrls} />
</Layout>
