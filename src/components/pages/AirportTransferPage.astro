---
import Layout from "../../layouts/Layout.astro";
import Header from "../layout/Header.astro";
import Footer from "../layout/Footer.astro";
import ReservationForm from "../ui/ReservationForm.astro";
import { getTranslations, getAlternateUrls } from "../../i18n";
import type { Locale } from "../../i18n";
import { siteConfig } from "../../config/site";
import { Phone, MessageCircle, Plane, BadgeEuro, Clock, UserCheck, ShieldCheck, CalendarCheck, Car } from "@lucide/astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
const at = t.airportTransfer;
const alternateUrls = getAlternateUrls("airportTransfer");

const whatsappUrl = `https://wa.me/${siteConfig.whatsapp.number}?text=${encodeURIComponent(at.whatsappMessage)}`;

const benefitIcons = [Plane, BadgeEuro, Clock, UserCheck];
const stepIcons = [CalendarCheck, Car, ShieldCheck];
---

<Layout
  title={`${at.metaTitle} ${siteConfig.address.city} | ${siteConfig.name}`}
  description={at.metaDescription}
  locale={locale}
  t={t}
  alternateUrls={alternateUrls}
>
  <Header locale={locale} t={t} alternateUrls={alternateUrls} />
  <main>
    <!-- Hero -->
    <section class="relative bg-dark pt-24 pb-16">
      <div class="absolute inset-0 bg-gradient-to-br from-dark via-gray-800 to-dark"></div>
      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-taxi-400 font-semibold text-sm uppercase tracking-wider mb-4">
            {at.tagline}
          </p>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-tight">
            {at.headline} {siteConfig.address.city} —
            <span class="text-taxi-400">{at.headlineHighlight}</span>
          </h1>
          <p class="mt-6 text-lg text-gray-300 max-w-xl">
            {at.description}
          </p>
          <div class="mt-8 flex flex-col sm:flex-row gap-4">
            <a
              href={`tel:${siteConfig.phone}`}
              class="inline-flex items-center justify-center gap-2 rounded-full bg-taxi-400 px-8 py-4 text-lg font-bold text-dark hover:bg-taxi-500 transition-colors"
            >
              <Phone class="h-5 w-5" />
              {at.ctaCall}
            </a>
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 rounded-full bg-green-500 px-8 py-4 text-lg font-bold text-white hover:bg-green-600 transition-colors"
            >
              <MessageCircle class="h-5 w-5" />
              WhatsApp
            </a>
          </div>
          <div class="mt-8 flex flex-wrap gap-x-6 gap-y-3 text-sm text-gray-400">
            <span class="flex items-center gap-2">
              <BadgeEuro class="h-4 w-4 text-taxi-400" />
              {at.featureFixedPrices}
            </span>
            <span class="flex items-center gap-2">
              <Clock class="h-4 w-4 text-taxi-400" />
              {at.feature247}
            </span>
            <span class="flex items-center gap-2">
              <UserCheck class="h-4 w-4 text-taxi-400" />
              {at.featureYourDriver}
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section class="py-20 bg-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <p class="text-taxi-500 font-semibold text-sm uppercase tracking-wider mb-2">
            {at.benefitsTagline}
          </p>
          <h2 class="text-3xl sm:text-4xl font-bold text-dark">
            {at.benefitsTitle}
          </h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
          {at.benefits.map((benefit, i) => {
            const Icon = benefitIcons[i];
            return (
              <div class="rounded-2xl bg-gray-50 border border-gray-100 p-6 text-center">
                <div class="inline-flex items-center justify-center rounded-xl bg-taxi-50 p-3 text-taxi-500 mb-4">
                  <Icon class="h-6 w-6" />
                </div>
                <h3 class="text-lg font-semibold text-dark mb-2">{benefit.title}</h3>
                <p class="text-sm text-gray-600">{benefit.description}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="py-20 bg-gray-50">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <p class="text-taxi-500 font-semibold text-sm uppercase tracking-wider mb-2">
            {at.howItWorksTagline}
          </p>
          <h2 class="text-3xl sm:text-4xl font-bold text-dark">
            {at.howItWorksTitle}
          </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {at.steps.map((item, i) => {
            const Icon = stepIcons[i];
            return (
              <div class="text-center">
                <div class="inline-flex items-center justify-center rounded-full bg-taxi-400 h-16 w-16 text-2xl font-bold text-dark mb-4">
                  {i + 1}
                </div>
                <h3 class="text-lg font-semibold text-dark mb-2">{item.title}</h3>
                <p class="text-sm text-gray-600">{item.description}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Reservation -->
    <section class="py-20 bg-white">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <p class="text-taxi-500 font-semibold text-sm uppercase tracking-wider mb-2">
            {at.reservationTagline}
          </p>
          <h2 class="text-3xl sm:text-4xl font-bold text-dark">
            {at.reservationTitle}
          </h2>
          <p class="mt-4 text-gray-600">
            {at.reservationDescription}
          </p>
        </div>
        <div class="max-w-lg mx-auto">
          <ReservationForm t={t} defaultTo={at.defaultDestination} id="airport-reservation-form" />
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 bg-gray-50">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <p class="text-taxi-500 font-semibold text-sm uppercase tracking-wider mb-2">
            {at.faqTagline}
          </p>
          <h2 class="text-3xl sm:text-4xl font-bold text-dark">
            {at.faqTitle}
          </h2>
        </div>
        <div class="space-y-4">
          {at.faqs.map((faq) => (
            <details class="group rounded-2xl bg-white border border-gray-100 overflow-hidden">
              <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-semibold text-dark hover:bg-gray-50 transition-colors">
                {faq.question}
                <span class="ml-4 text-taxi-500 transition-transform group-open:rotate-45">+</span>
              </summary>
              <div class="px-6 pb-4 text-sm text-gray-600 leading-relaxed">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} t={t} alternateUrls={alternateUrls} />

  <!-- FAQ Structured Data -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: at.faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: faq.answer,
        },
      })),
    })}
  />
</Layout>
