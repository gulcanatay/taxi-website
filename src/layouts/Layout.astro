---
import "../styles/global.css";
import { siteConfig } from "../config/site";
import { trackingConfig } from "../config/tracking";
import WhatsAppFloat from "../components/ui/WhatsAppFloat.astro";
import CookieConsent from "../components/ui/CookieConsent.astro";
import type { Locale } from "../i18n";
import type { Translations } from "../i18n/types";

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
  t?: Translations;
  alternateUrls?: Record<Locale, string>;
}

const {
  title = siteConfig.name,
  description = "",
  locale = "de",
  t,
  alternateUrls,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, siteConfig.url).href;

const ogLocaleMap: Record<Locale, string> = {
  de: "de_DE",
  en: "en_US",
  fr: "fr_FR",
};

const otherLocales = (["de", "en", "fr"] as Locale[]).filter((l) => l !== locale);
---

<!doctype html>
<html lang={locale} class="scroll-smooth bg-dark">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#231f20" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- hreflang -->
    {alternateUrls && Object.entries(alternateUrls).map(([loc, path]) => (
      <link rel="alternate" hreflang={loc} href={new URL(path, siteConfig.url).href} />
    ))}
    {alternateUrls && (
      <link rel="alternate" hreflang="x-default" href={new URL(alternateUrls.de, siteConfig.url).href} />
    )}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocaleMap[locale]} />
    {otherLocales.map((l) => (
      <meta property="og:locale:alternate" content={ogLocaleMap[l]} />
    ))}
    <meta property="og:url" content={canonicalUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Google Consent Mode v2 defaults (must load before GTM) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied'
      });
    </script>

    <!-- Google Tag Manager -->
    <script is:inline define:vars={{ gtmId: trackingConfig.gtmId }}>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer',gtmId);
    </script>

    <!-- Google Maps Places API -->
    <script
      async
      src={`https://maps.googleapis.com/maps/api/js?key=${import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY}&libraries=places&loading=async`}
    ></script>

    <title>{title}</title>

    <!-- Language detection & redirect on first visit -->
    {alternateUrls && (
      <script
        is:inline
        data-locale={locale}
        data-alternate-urls={JSON.stringify(alternateUrls)}
      >
        (function () {
          var script = document.currentScript;
          var currentLocale = script.getAttribute("data-locale");
          var alternateUrls = JSON.parse(script.getAttribute("data-alternate-urls"));

          // Skip if user already made a manual language choice
          if (localStorage.getItem("lang-preference")) return;
          // Skip if we already ran detection for this session
          if (localStorage.getItem("lang-detected")) return;

          localStorage.setItem("lang-detected", "true");

          var supported = ["de", "en", "fr"];
          var browserLangs = navigator.languages || [navigator.language];
          var matched = null;

          for (var i = 0; i < browserLangs.length; i++) {
            var lang = browserLangs[i].toLowerCase().split("-")[0];
            if (supported.indexOf(lang) !== -1) {
              matched = lang;
              break;
            }
          }

          if (matched && matched !== currentLocale && alternateUrls[matched]) {
            window.location.replace(alternateUrls[matched]);
          }
        })();
      </script>
    )}

    <!-- JSON-LD Structured Data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "TaxiService",
        name: siteConfig.name,
        description: description,
        telephone: siteConfig.phone,
        email: siteConfig.email,
        inLanguage: locale,
        address: {
          "@type": "PostalAddress",
          streetAddress: siteConfig.address.street,
          postalCode: siteConfig.address.zip,
          addressLocality: siteConfig.address.city,
          addressCountry: "DE",
        },
      })}
    />
  </head>
  <body class="bg-white text-dark antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src={`https://www.googletagmanager.com/ns.html?id=${trackingConfig.gtmId}`}
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>

    <slot />
    {t && <WhatsAppFloat t={t} />}
    {t && <CookieConsent t={t} locale={locale} />}
  </body>
</html>
